{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "quesedice.com.ar" }
      ],
      "destination": "https://www.quesedice.com.ar/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/story/:id",
      "destination": "/api/story?id=:id"
    },
    {
      "source": "/story/:id/:slug",
      "destination": "/api/story?id=:id"
    },
    {
      "source": "/r",
      "destination": "/api/r"
    },
    {
      "source": "/((?!api/|css/|redaccion/|sobre-qsd/|rqsd/|qa/|lib/|icons/|manifest\\.webmanifest|Logo_qsd\\.png|service-worker\\.js|offline\\.html|r\\.html|robots\\.txt|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
